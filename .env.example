# Anthropic Claude API 키 (필수 — 기본 추론 모델) — 대회 지급 키 사용
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API 키 (필수 — 임베딩(RAG)·STT(whisper)·TTS 전용)
OPENAI_API_KEY=sk-...

# 모델 오버라이드 (선택) — 미설정 시 기본값(claude-opus-4-8) 사용
# 모델명이 claude로 시작하면 Anthropic, 아니면 OpenAI로 자동 라우팅 (즉시 롤백 가능)
# MODEL_SMART=claude-opus-4-8
# MODEL_FAST=claude-haiku-4-5
# MODEL_SMART=gpt-4o        <- OpenAI로 롤백 시
# MODEL_FAST=gpt-4o-mini

# 적대 검증(GAN) 자동 실행 (선택) — 1이면 응답마다 Critic·Defender·Judge 심층 검증 후
# '재생성필요' 판정 시 자동 재생성 (응답당 +60~90초, 시연·품질 모드용. 기본 꺼짐)
# GAN_AUTO=1

# 노드별 지연·재시도·검수 결과 구조화 로깅 (선택) — 1이면 그래프 실행 중 stderr에 출력
# LangSmith 트레이싱을 켜려면 아래 두 변수를 설정 (LangGraph가 전 노드 자동 트레이싱)
# JB_LOG=1
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
